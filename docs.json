{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "B3OS Docs",
  "colors": {
    "primary": "#007AFF",
    "light": "#4DA6FF",
    "dark": "#0056CC"
  },
  "favicon": "/favicon.png",
  "navigation": {
    "languages": [
      {
        "language": "en",
        "name": "English",
        "tabs": [
          {
            "icon": "circle-nodes",
            "tab": "Platform",
            "groups": [
              {
                "group": "Getting Started",
                "pages": ["index", "quickstart"]
              },
              {
                "group": "Workflows",
                "pages": [
                  "platform/architecture",
                  "platform/concepts",
                  "platform/workflows",
                  "platform/triggers",
                  "platform/actions-overview",
                  "platform/expressions"
                ]
              },
              {
                "group": "AI Agent",
                "pages": ["platform/ai-agent"]
              },
              {
                "group": "Organizations",
                "pages": ["platform/organizations", "platform/connectors", "platform/wallets"]
              },
              {
                "group": "Security",
                "pages": ["platform/security"]
              }
            ],
            "global": {
              "anchors": [
                {
                  "anchor": "B3OS App",
                  "href": "https://b3os.org",
                  "icon": "globe"
                },
                {
                  "anchor": "Discord",
                  "href": "https://discord.gg/b3dotfun",
                  "icon": "discord"
                }
              ]
            }
          },
          {
            "icon": "code",
            "tab": "API Reference",
            "groups": [
              {
                "group": "Overview",
                "pages": ["api/introduction", "api/authentication"]
              },
              {
                "group": "Endpoints",
                "pages": [
                  {
                    "group": "B3OS Workflow API",
                    "openapi": {
                      "source": "/openapi/b3os-workflow.json",
                      "directory": "api/reference"
                    }
                  }
                ]
              }
            ]
          },
          {
            "icon": "bolt",
            "tab": "Actions",
            "groups": [
              {
                "group": "Overview",
                "pages": ["actions/introduction", "actions/built-in", "actions/triggers"]
              },
              {
                "group": "Providers",
                "pages": ["actions/evm-onchain", "actions/defi", "actions/messaging"]
              }
            ]
          }
        ]
      }
    ]
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude", "perplexity", "cursor", "vscode"]
  },
  "scripts": [
    {
      "src": "/replace-footer.js",
      "strategy": "lazyOnload"
    }
  ]
}
